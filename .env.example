OPENROUTER_API_KEY=your_openrouter_api_key_here
PORT=3000
SONAUTO_API_KEY=your_sonauto_api_key_here
BYTEZ_API_KEY=your_bytez_api_key_here
USE_BYTEZ=false

# Supabase Auth & Database
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_KEY=eyJhbGciOi...your-service-role-key

# HubSpot CRM Integration
# Get from: app.hubspot.com → Settings → Integrations → Private Apps → Create app
# Required scopes: crm.objects.contacts.read/write, crm.objects.deals.write, timeline
# Run `node hubspot-setup.js` once after setting this key to create custom properties
HUBSPOT_API_KEY=pat-na1-your-private-app-token-here
